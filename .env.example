# ─────────────────────────────────────────────
# IoT Security Appliance — Configuration
# Copy this to .env and fill in your values
# ─────────────────────────────────────────────

# !! REQUIRED: Your Groq Cloud API key
# Get one free at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Groq model to use (llama3-70b-8192 is best for analysis)
# Options: llama3-70b-8192, llama3-8b-8192, mixtral-8x7b-32768
GROQ_MODEL=llama3-70b-8192

# ─────────────────────────────────────────────
# Network Configuration
# ─────────────────────────────────────────────

# Network range to scan
# Set to "auto" to auto-detect your local network
# Or specify explicitly: 192.168.1.0/24
NETWORK_RANGE=auto

# How often to run background scans (in seconds)
# Default: 120 (2 minutes)
SCAN_INTERVAL_SECONDS=120

# ─────────────────────────────────────────────
# Server Configuration
# ─────────────────────────────────────────────

HOST=0.0.0.0
PORT=8000

# Set to "true" for development mode with auto-reload
DEV=false

# ─────────────────────────────────────────────
# Notes:
# - nmap must be installed: sudo apt install nmap
# - For full scanning capabilities, run with: sudo python backend/main.py
#   (nmap OS detection and SYN scan require root privileges)
# - On macOS: brew install nmap
# ─────────────────────────────────────────────
